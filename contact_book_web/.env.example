# Flask application settings
SECRET_KEY=your-custom-session-secret-key
FLASK_DEBUG=False

# HTTP Basic Auth credentials (optional locally, recommended for production)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=your-secure-deployment-password

# Port binding (Render sets this dynamically)
PORT=5000

# SQLite Database Location path (optional)
# Point this to a directory inside Render's persistent disk volume path (e.g. /data/contacts.db)
SQLITE_DB_PATH=/data/contacts.db
